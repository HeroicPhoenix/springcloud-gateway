<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">

    <Properties>
        <Property name="APP_NAME">springcloud-gateway</Property>
        <Property name="LOG_PATH">logs</Property>

        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n
        </Property>
    </Properties>

    <Appenders>

        <!-- 控制台 -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- 文件 -->
        <RollingFile name="File"
                     fileName="${LOG_PATH}/${APP_NAME}.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}.log.gz">

            <PatternLayout pattern="${LOG_PATTERN}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>

            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>

    <Loggers>

        <!-- 你自己的代码 -->
        <Logger name="com.lvwyh.gateway" level="DEBUG"/>

        <!-- Gateway 路由日志 -->
        <Logger name="org.springframework.cloud.gateway" level="DEBUG"/>

        <!-- 负载均衡 -->
        <Logger name="org.springframework.cloud.loadbalancer" level="DEBUG"/>

        <!-- Netty HTTP -->
        <Logger name="reactor.netty.http.client" level="DEBUG"/>

        <!-- Nacos -->
        <Logger name="com.alibaba.cloud.nacos" level="INFO"/>

        <!-- 根日志 -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

    </Loggers>

</Configuration>